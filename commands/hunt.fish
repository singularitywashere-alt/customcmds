function hunt --description "Find the best exposed API and attack it automatically"     if test (count $argv) -ne 1         echo "Usage: hunt <target-website>"         return 1     end      set target $argv[1]     echo "==> HUNTING: $target"     echo "    Scanning for exposed APIs (this may take a moment) …"      # Get the list of exposed endpoints via locate-flaw --list (silent mode)     set endpoints (locate-flaw --list $target 2>/dev/null)      if test (count $endpoints) -eq 0         echo "    No API endpoints found. Nothing to attack."         return 0     end      echo "    Found $(count $endpoints) endpoint(s). Selecting the most promising one …"      set best_endpoint ""     set best_score -1      for ep in $endpoints         set code (curl -sS -o /dev/null -w "%{http_code}" --max-time 5 "$ep" 2>/dev/null)         set qs (string replace -r '^[^?]*\?' '' "$ep")         set param_count 0         if test "$qs" != "$ep"             set param_count (echo "$qs" | tr '&' '\n' | wc -l)         end          set score 0         if test "$code" = "200"             set score (math 10 + $param_count)         else if test "$code" = "401" -o "$code" = "403"             set score (math 5 + $param_count)         end          if test $score -gt $best_score             set best_score $score             set best_endpoint $ep         end     end      if test -z "$best_endpoint"         echo "    Could not determine a suitable target. Exiting."         return 1     end      echo "    Most promising target: $best_endpoint"     echo "==> ATTACKING: $best_endpoint"     attack "$best_endpoint" end
